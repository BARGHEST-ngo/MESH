2026-03-20T15:19:35.907517Z 01E # Reproducibility flags:
2026-03-20T15:19:35.907517Z 01E #   CANONICAL_SRC      symlink with a fixed path so gomobile's generated
2026-03-20T15:19:35.907518Z 01E #                      replace directives always embed the same module
2026-03-20T15:19:35.907519Z 01E #                      path in the Go build info, regardless of the
2026-03-20T15:19:35.907519Z 01E #                      actual workspace location on different machines.
2026-03-20T15:19:35.907520Z 01E #   GOCACHE=<fresh-dir> ensures gobind's packages.Load always starts from
2026-03-20T15:19:35.907520Z 01E #                       a clean cache, avoiding non-deterministic type
2026-03-20T15:19:35.907521Z 01E #                       resolution (golang/go#33687).  Without this, the
2026-03-20T15:19:35.907522Z 01E #                       build cache state leaks into gobind's output,
2026-03-20T15:19:35.907522Z 01E #                       causing invokevirtual ↔ invokeinterface bytecode
2026-03-20T15:19:35.907523Z 01E #                       differences in classes.jar across machines.
2026-03-20T15:19:35.907524Z 01E #   -buildid=          zeroes the Go build ID
2026-03-20T15:19:35.907524Z 01E #   -trimpath          removes host filesystem paths from the binary
2026-03-20T15:19:35.907525Z 01E #                      NOTE: passed directly to gomobile bind because
2026-03-20T15:19:35.907526Z 01E #                      gomobile strips the parent process environment
2026-03-20T15:19:35.907526Z 01E #                      (GOFLAGS, CGO_CFLAGS, GOCACHE, GOTOOLCHAIN, etc.)
2026-03-20T15:19:35.907527Z 01E #                      when spawning `go build` subprocesses.  Only
2026-03-20T15:19:35.907527Z 01E #                      gomobile's own CLI flags survive to the subprocess.
2026-03-20T15:19:35.907528Z 01E #   -buildvcs=false    prevents embedding VCS info (commit hash, dirty flag)
2026-03-20T15:19:35.907529Z 01E #   CGO_CFLAGS         strips absolute paths from C debug info
2026-03-20T15:19:35.907529Z 01E #   -linkmode=external uses the NDK linker (required for 16kb page alignment)
2026-03-20T15:19:35.907538Z 01E GOBIND_CACHE=$(mktemp -d) && \
2026-03-20T15:19:35.907538Z 01E CANONICAL_SRC="/tmp/_mesh_build_src" && \
2026-03-20T15:19:35.907539Z 01E ln -sfn "$(cd .. && pwd)" "$CANONICAL_SRC" && \
2026-03-20T15:19:35.907539Z 01E trap "rm -rf $GOBIND_CACHE $CANONICAL_SRC" EXIT && \
2026-03-20T15:19:35.907540Z 01E cd "$CANONICAL_SRC/android-client" && \
2026-03-20T15:19:35.907540Z 01E CGO_CFLAGS="-ffile-prefix-map=$(pwd)=. -ffile-prefix-map=${HOME}=." \
